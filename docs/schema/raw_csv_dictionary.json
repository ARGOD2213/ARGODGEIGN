{
  "source": "s3://iot-alert-engine-mahindra/data/industrial_dummy_1gb.csv",
  "columns": [
    { "name": "event_id", "type": "bigint", "unit": "count" },
    { "name": "timestamp", "type": "string(ISO-8601 UTC)", "unit": "UTC timestamp" },
    { "name": "facility_id", "type": "string", "unit": "n/a" },
    { "name": "area", "type": "string", "unit": "n/a" },
    { "name": "cell_name", "type": "string", "unit": "n/a" },
    { "name": "machine_id", "type": "string", "unit": "n/a" },
    { "name": "machine_class", "type": "string", "unit": "n/a" },
    { "name": "product_stream", "type": "string", "unit": "n/a" },
    { "name": "sensor_type", "type": "string", "unit": "enum" },
    { "name": "sensor_category", "type": "string", "unit": "n/a" },
    { "name": "unit", "type": "string", "unit": "n/a" },
    { "name": "value", "type": "double", "unit": "dynamic by sensor" },
    { "name": "status", "type": "string", "unit": "NORMAL|WARNING|CRITICAL" },
    { "name": "warning_threshold", "type": "double", "unit": "same as sensor unit" },
    { "name": "critical_threshold", "type": "double", "unit": "same as sensor unit" },
    { "name": "min_value", "type": "double", "unit": "same as sensor unit" },
    { "name": "max_value", "type": "double", "unit": "same as sensor unit" },
    { "name": "avg_value", "type": "double", "unit": "same as sensor unit" },
    { "name": "delta_from_previous", "type": "double", "unit": "same as sensor unit" },
    { "name": "weather_temp_c", "type": "double", "unit": "C" },
    { "name": "weather_humidity_pct", "type": "double", "unit": "%" },
    { "name": "weather_condition", "type": "string", "unit": "n/a" },
    { "name": "weather_wind_speed_ms", "type": "double", "unit": "m/s" },
    { "name": "weather_correlation_note", "type": "string", "unit": "n/a" },
    { "name": "weather_alert_active", "type": "boolean", "unit": "true|false" },
    { "name": "ai_risk_score", "type": "int", "unit": "0-100" },
    { "name": "ai_risk_level", "type": "string", "unit": "LOW|MEDIUM|HIGH|CRITICAL" },
    { "name": "llm_consensus", "type": "string", "unit": "n/a" },
    { "name": "ai_incident_summary", "type": "string", "unit": "n/a" },
    { "name": "ai_recommended_action", "type": "string", "unit": "n/a" },
    { "name": "ai_predicted_failure_eta", "type": "string", "unit": "time window" },
    { "name": "sns_message_id", "type": "string", "unit": "n/a" },
    { "name": "sqs_message_id", "type": "string", "unit": "n/a" },
    { "name": "latitude", "type": "double", "unit": "degrees" },
    { "name": "longitude", "type": "double", "unit": "degrees" }
  ]
}
