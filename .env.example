# Copy this to .env and fill values as needed.
# For EC2 demo mode, prefer instance roles or temporary credentials instead of static keys.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

AWS_SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:iot-alerts
AWS_SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789012/iot-events.fifo
AWS_SQS_DLQ_URL=https://sqs.ap-south-1.amazonaws.com/123456789012/iot-events-dlq.fifo

WEATHER_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_ANALYSIS_ENABLED=true

# Dashboard auth - set these on EC2, never commit real values
ARGUS_DASHBOARD_USER=argus
ARGUS_DASHBOARD_PASS=changeme
